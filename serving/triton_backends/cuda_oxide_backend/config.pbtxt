name: "cuda_oxide_backend"
backend: "python"
max_batch_size: 8

# Input: packed token embeddings or raw float buffer
# Shape: [batch, seq_len, hidden_dim] — update when kernel shapes are finalized
input [
  {
    name: "INPUT_0"
    data_type: TYPE_FP32
    dims: [ 512, 768 ]
  }
]

output [
  {
    name: "OUTPUT_0"
    data_type: TYPE_FP32
    dims: [ 512, 768 ]
  }
]

instance_group [
  {
    kind: KIND_GPU
    count: 1
    gpus: [ 0 ]
  }
]

# TODO: enable dynamic batching once kernel supports variable batch sizes
# dynamic_batching {
#   preferred_batch_size: [ 1, 4, 8 ]
#   max_queue_delay_microseconds: 100
# }
